    "_postman_id": "0d7c3b7d-7c3a-4f4b-9ef8-43b6d9aa1f3c",
    "name": "Tourism Booking System API",
    "description": "Postman collection for the Laravel Tourism Booking System API. Start with Tourist Login or Admin Login. The login request saves `token` and `current_token_id`; protected requests use `Authorization: Bearer {{token}}`. Use Create Extra Token before Revoke Token by ID so `token_id` points to a separate token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth and Tokens",
      "item": [
        {
          "name": "Tourist Login - Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns token', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.expect(json.token_id).to.exist;",
                  "  pm.environment.set('token', json.token);",
                  "  pm.environment.set('current_token_id', json.token_id);",
                  "  pm.environment.unset('token_id');",
                  "  pm.environment.unset('extra_token');",
                  "  pm.environment.set('user_id', json.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{tourist_email}}\",\n  \"password\": \"{{tourist_password}}\",\n  \"token_name\": \"Postman Tourist Token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Run this first for tourist API testing. It creates a personal access token and saves it as `token`; the current token id is saved as `current_token_id`."
          },
          "response": []
        },
        {
          "name": "Admin Login - Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login returns token', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.expect(json.token_id).to.exist;",
                  "  pm.environment.set('token', json.token);",
                  "  pm.environment.set('current_token_id', json.token_id);",
                  "  pm.environment.unset('token_id');",
                  "  pm.environment.unset('extra_token');",
                  "  pm.environment.set('admin_id', json.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"token_name\": \"Postman Admin Token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "login"
              ]
            },
            "description": "Run this first for admin API testing. It creates a personal access token and saves it as `token`; the current token id is saved as `current_token_id`."
          },
          "response": []
        },
        {
          "name": "Create Extra Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Extra token is created and saved', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.expect(json.token_id).to.exist;",
                  "  pm.environment.set('extra_token', json.token);",
                  "  pm.environment.set('token_id', json.token_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token_name\": \"Extra Postman Token\",\n  \"abilities\": [\"bookings:read\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tokens",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tokens"
              ]
            }
          },
          "description": "Creates a second token using the currently saved Bearer token. This saves the new token id as `token_id`, which is the safe target for Revoke Token by ID.",
          "response": []
        },
        {
          "name": "List Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tokens are listed', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.tokens).to.be.an('array');",
                  "  const extra = json.tokens.find(token => token.name === 'Extra Postman Token');",
                  "  if (extra) {",
                  "    pm.environment.set('token_id', extra.id);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tokens"
              ]
            }
          },
          "description": "Lists personal access tokens for the current account. If an `Extra Postman Token` exists, its id is saved as `token_id` for revoke testing.",
          "response": []
        },
        {
          "name": "Revoke Token by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Token is revoked by id', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('revoked');",
                  "  pm.environment.unset('token_id');",
                  "  pm.environment.unset('extra_token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens/{{token_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tokens",
                "{{token_id}}"
              ]
            }
          },
          "description": "Revokes the token id stored in `token_id`. Recommended flow: Login -> Create Extra Token -> Revoke Token by ID. This avoids revoking your current login token by mistake.",
          "response": []
        },
        {
          "name": "Revoke All Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('All tokens are revoked', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.environment.unset('token');",
                  "  pm.environment.unset('current_token_id');",
                  "  pm.environment.unset('token_id');",
                  "  pm.environment.unset('extra_token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens/revoke-all",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tokens",
                "revoke-all"
              ]
            }
          },
          "description": "Revokes every token for the logged-in account. After this, run Login again before calling protected endpoints.",
          "response": []
        },
        {
          "name": "Logout - Revoke Current Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Current token is revoked', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.environment.unset('token');",
                  "  pm.environment.unset('current_token_id');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "logout"
              ]
            }
          },
          "description": "Revokes only the current Bearer token. After this, run Login again before protected requests.",
          "response": []
        }
      ]
    },
